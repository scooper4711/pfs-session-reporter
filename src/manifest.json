{
  "manifest_version": 3,
  "name": "PFS Session Reporter",
  "version": "0.1.0",
  "description": "Automates filling the Paizo.com PFS2E session reporting form from clipboard data",
  "permissions": [
    "clipboardRead",
    "activeTab"
  ],
  "host_permissions": [
    "https://paizo.com/cgi-bin/WebObjects/Store.woa/*",
    "https://www.paizo.com/cgi-bin/WebObjects/Store.woa/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://paizo.com/cgi-bin/WebObjects/Store.woa/*",
        "https://www.paizo.com/cgi-bin/WebObjects/Store.woa/*"
      ],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "PFS Session Reporter"
  }
}
